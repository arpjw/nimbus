# Required
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# API key enforcement (set to false only for local development)
REQUIRE_API_KEY=true

# Open mode: set to true to disable key enforcement for local/self-hosted use
# NIMBUS_OPEN_MODE=false

# Encryption key for BYOK storage (required if using BYOK)
# ENCRYPTION_KEY=change-me-to-a-random-secret

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=

# Redis (required for task streaming and approval flow)
REDIS_URL=redis://localhost:6379/0

# Optional: OpenAI key enables gpt-4o as the self-reviewer
# OPENAI_API_KEY=sk-...

# Optional: Sentry error tracking
# SENTRY_DSN=https://...@sentry.io/...

# Sandbox verification (requires Docker)
# SANDBOX_VERIFICATION=false
# SANDBOX_IMAGE=python:3.12-slim

# Model configuration
PLANNER_MODEL=claude-opus-4-6
IMPLEMENTER_MODEL=claude-sonnet-4-6
REVIEWER_MODEL=claude-sonnet-4-6

# Workspace
WORKSPACE_BASE_DIR=/tmp/nimbus-workspaces

# Slack integration
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CLIENT_ID=...
# SLACK_CLIENT_SECRET=...

# Linear integration
# LINEAR_API_KEY=lin_api_...
# LINEAR_WEBHOOK_SECRET=...

# App base URL (used in outbound links)
APP_BASE_URL=http://localhost:8000
